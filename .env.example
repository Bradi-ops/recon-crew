# =============================================================================
# ReconCrew v3 - Configuration
# =============================================================================
# Copy this file to .env and edit with your values.
# .env is in .gitignore so your secrets stay local.
# =============================================================================

# --- LLM Provider ---
# Options: "lmstudio", "openai", "anthropic"
LLM_PROVIDER=lmstudio

# --- LM Studio (local models) ---
LM_STUDIO_HOST=http://192.168.1.1:1234
LM_STUDIO_MODEL=qwen2.5-14b-instruct

# --- OpenAI API (when using GPT) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# --- Anthropic API (when using Claude) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Scan Settings ---
MAX_CRAWL_DEPTH=3
MAX_PAGES=50
REQUEST_TIMEOUT=10
REQUEST_DELAY=0.3
FUZZ_THREADS=50
MAX_FUZZ_ENDPOINTS=100
